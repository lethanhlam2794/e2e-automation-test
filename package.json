{
  "name": "e2e-automation",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "test": "playwright test",
    "test:happy": "playwright test --grep @happy",
    "test:project-a": "playwright test --project=project-a --grep @happy",
    "test:project-a:headed": "playwright test --project=project-a --grep @happy --headed",
    "test:project-a:debug": "playwright test --project=project-a --grep @happy --debug",
    "test:project-a:ui": "playwright test --project=project-a --grep @happy --ui",
    "test:project-b": "playwright test --project=project-b --grep @happy",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3"
  }
}
